        <Key android:codes="50" android:keyOutputText="*ا&lt;🌚*\n*ا    //>*      \n*ا ._\\\\_*\n⇑\n     *🎀جمٍۧـ{مبارڪَـ(😘)ـهۂ}ـ؏ـهۂ🎀ํฺ  😘😘🌹❤💯💯❀😻*\nُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۫۫۫۫۫ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۫۫۫۫۫ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۫۫۫۫۫ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫​​​​​​​​​​​​​​​​ٰٰٰ۪ۦٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۫۫ۦُُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۫۫۫۫۫۫ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫ۦُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫              ُٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۫۫۫ۦٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰٰ۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۪۫۫۫۫۫۫۫۫۫۫" android:keyLabel="جمعه" />
